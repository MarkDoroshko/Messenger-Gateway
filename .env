# ==========================================
# Shared secrets
# ==========================================
JWT_SECRET_KEY=super_secret_jwt_key_change_in_production
INTERNAL_SERVICE_USERNAME=auth-service
INTERNAL_SERVICE_PASSWORD=internal_secret_password

# ==========================================
# Auth Service
# ==========================================
AUTH_PORT=8080
AUTH_HOST=0.0.0.0
SERVER_TIMEOUT=10
DB_TIMEOUT=5
JWT_ACCESS_TOKEN_EXPIRATION=24
JWT_REFRESH_TOKEN_EXPIRATION=168
USER_SERVICE_URL=http://user-service:8080

# Auth DB
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=auth_password
AUTH_POSTGRES_DB=auth_db
AUTH_POSTGRES_PORT=5432
AUTH_POSTGRES_HOST=db-auth
AUTH_POSTGRES_USE_SSL=disable

# ==========================================
# User Service
# ==========================================
USER_SERVER_PORT=8080

# User DB
USER_POSTGRES_USER=user_service_user
USER_POSTGRES_PASSWORD=user_password
USER_POSTGRES_DB=user_service_db
USER_POSTGRES_PORT=5432
USER_POSTGRES_HOST=db-user

# ==========================================
# Gateway
# ==========================================
GATEWAY_PORT=80
